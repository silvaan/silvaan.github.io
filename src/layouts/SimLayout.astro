---
import BaseLayout from './BaseLayout.astro';
import { getArea } from '../data/tools';

interface Props {
  areaSlug: string;
  title: string;
  description: string;
}

const { areaSlug, title, description } = Astro.props;
const area = getArea(areaSlug);
---

<BaseLayout title={title} description={description} wide>
  <div class="breadcrumb">
    <a href="/simulations">Simulations</a>
    <span>/</span>
    <a href={`/simulations/${areaSlug}`}>{area?.title ?? areaSlug}</a>
    <span>/</span>
    <span>{title}</span>
  </div>

  <div class="page-head">
    <span class="eyebrow">{area?.title ?? 'Simulator'}</span>
    <h1>{title}</h1>
    <p class="lead">{description}</p>
  </div>

  <slot />
</BaseLayout>

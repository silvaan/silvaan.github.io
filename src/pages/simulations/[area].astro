---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AREAS } from '../../data/tools';

export function getStaticPaths() {
  return AREAS.map((area) => ({
    params: { area: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
---

<BaseLayout title={area.title} description={area.description} wide>
  <div class="breadcrumb">
    <a href="/simulations">Simulations</a>
    <span>/</span>
    <span>{area.title}</span>
  </div>

  <div class="page-head">
    <span class="eyebrow">{area.title}</span>
    <h1>{area.title} simulators</h1>
    <p class="lead">{area.description}</p>
  </div>

  <div class="card-grid">
    {
      area.simulators.map((sim) =>
        sim.status === 'soon' ? (
          <div class="card" style="opacity:.6">
            <h3>{sim.title}</h3>
            <p>{sim.description}</p>
            <div class="card-foot">
              <span class="badge-soon">coming soon</span>
            </div>
          </div>
        ) : (
          <a class="card" href={sim.href}>
            <h3>{sim.title}</h3>
            <p>{sim.description}</p>
            <div class="card-foot">
              <span>Open simulator</span>
              <span class="arrow">→</span>
            </div>
          </a>
        )
      )
    }
  </div>
</BaseLayout>

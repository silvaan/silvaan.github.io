---
import SimLayout from '../../../layouts/SimLayout.astro';
---

<SimLayout
  areaSlug="calculus"
  title="Scalar Fields & Gradients"
  description="A scalar field assigns a number to every point in space. Here it is a 3D density cloud, coloured low to high. Turn on the gradient field to see the direction of steepest increase at points throughout the volume."
>
  <div class="sim">
    <div class="sim-stage">
      <canvas id="cloud" class="probe-canvas" width="640" height="640"></canvas>
    </div>

    <div class="sim-panel">
      <div class="control">
        <label>Points <b id="ptval">3000</b></label>
        <input type="range" id="pts" min="600" max="6000" step="200" value="3000" />
      </div>

      <div class="control">
        <label>Gradient field</label>
        <div class="seg" id="grad">
          <button data-on="0">Off</button>
          <button data-on="1" class="active">On</button>
        </div>
      </div>

      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn" id="spin">Pause spin</button>
        <button class="btn ghost" id="regen">New field</button>
      </div>

      <p style="font-size:.82rem;color:var(--text-faint);margin:0;line-height:1.5">
        Drag to orbit the cloud. Colour runs from low density (blue) to high
        (red). The white arrows are the gradient: each one points toward denser
        regions, longer where the field changes faster.
      </p>
    </div>
  </div>
</SimLayout>

<script>
  const canvas = document.getElementById('cloud') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const W = canvas.width;
  const H = canvas.height;
  const CX = W / 2;
  const CY = H / 2;
  const CAM = 3.1; // camera distance
  const FOCAL = 2.7;
  const SCALE = 270;
  const MAX = 6000;

  type Blob = { x: number; y: number; z: number; s: number; a: number };
  let blobs: Blob[] = [];

  // cloud points
  const px = new Float32Array(MAX);
  const py = new Float32Array(MAX);
  const pz = new Float32Array(MAX);
  const pt = new Float32Array(MAX); // normalised density [0,1] for colour
  let nPoints = 0;

  // gradient arrows: base + tip in world space
  let arrows: { bx: number; by: number; bz: number; tx: number; ty: number; tz: number }[] = [];

  const state = { count: 3000, showGrad: true, spin: true, yaw: 0.6, pitch: -0.5 };

  function field(x: number, y: number, z: number) {
    let f = 0;
    for (const b of blobs) {
      const dx = x - b.x, dy = y - b.y, dz = z - b.z;
      f += b.a * Math.exp(-(dx * dx + dy * dy + dz * dz) / (2 * b.s * b.s));
    }
    return f;
  }

  function turbo(t: number) {
    t = Math.max(0, Math.min(1, t));
    const stops = [
      [26, 44, 130],
      [22, 150, 210],
      [40, 200, 120],
      [245, 205, 60],
      [240, 70, 55],
    ];
    const seg = t * (stops.length - 1);
    const i = Math.min(stops.length - 2, Math.floor(seg));
    const f = seg - i;
    const a = stops[i], b = stops[i + 1];
    return [
      (a[0] + (b[0] - a[0]) * f) | 0,
      (a[1] + (b[1] - a[1]) * f) | 0,
      (a[2] + (b[2] - a[2]) * f) | 0,
    ];
  }

  function generate() {
    const n = 4 + Math.floor(Math.random() * 3);
    blobs = [];
    for (let i = 0; i < n; i++) {
      blobs.push({
        x: Math.random() * 1.4 - 0.7,
        y: Math.random() * 1.4 - 0.7,
        z: Math.random() * 1.4 - 0.7,
        s: 0.18 + Math.random() * 0.2,
        a: (Math.random() < 0.72 ? 1 : -1) * (0.5 + Math.random() * 1.0),
      });
    }

    // estimate min/max density
    let fMin = Infinity, fMax = -Infinity;
    for (let i = 0; i < 6000; i++) {
      const f = field(Math.random() * 2.4 - 1.2, Math.random() * 2.4 - 1.2, Math.random() * 2.4 - 1.2);
      if (f < fMin) fMin = f;
      if (f > fMax) fMax = f;
    }
    const span = fMax - fMin || 1;

    // rejection-sample a density-weighted point cloud
    nPoints = 0;
    let tries = 0;
    while (nPoints < MAX && tries < MAX * 60) {
      tries++;
      const x = Math.random() * 2.2 - 1.1;
      const y = Math.random() * 2.2 - 1.1;
      const z = Math.random() * 2.2 - 1.1;
      const t = (field(x, y, z) - fMin) / span;
      const p = Math.pow(Math.max(0, t), 1.6); // cluster in dense regions, keep faint halo
      if (Math.random() < p * 0.9 + 0.02) {
        px[nPoints] = x;
        py[nPoints] = y;
        pz[nPoints] = z;
        pt[nPoints] = t;
        nPoints++;
      }
    }

    // gradient arrows on a coarse grid
    arrows = [];
    const G = 4;
    const h = 0.02;
    for (let ix = 0; ix <= G; ix++)
      for (let iy = 0; iy <= G; iy++)
        for (let iz = 0; iz <= G; iz++) {
          const x = -0.85 + (1.7 * ix) / G;
          const y = -0.85 + (1.7 * iy) / G;
          const z = -0.85 + (1.7 * iz) / G;
          const t = (field(x, y, z) - fMin) / span;
          if (t < 0.18) continue; // skip near-empty voids
          const gx = (field(x + h, y, z) - field(x - h, y, z)) / (2 * h);
          const gy = (field(x, y + h, z) - field(x, y - h, z)) / (2 * h);
          const gz = (field(x, y, z + h) - field(x, y, z - h)) / (2 * h);
          const gm = Math.hypot(gx, gy, gz);
          if (gm < 1e-4) continue;
          const L = Math.min(0.26, 0.06 + gm * 0.12);
          arrows.push({
            bx: x, by: y, bz: z,
            tx: x + (gx / gm) * L,
            ty: y + (gy / gm) * L,
            tz: z + (gz / gm) * L,
          });
        }
  }

  function project(x: number, y: number, z: number) {
    const cy = Math.cos(state.yaw), sy = Math.sin(state.yaw);
    const cp = Math.cos(state.pitch), sp = Math.sin(state.pitch);
    // yaw around Y
    const x1 = x * cy + z * sy;
    const z1 = -x * sy + z * cy;
    const y1 = y;
    // pitch around X
    const y2 = y1 * cp - z1 * sp;
    const z2 = y1 * sp + z1 * cp;
    const zc = z2 + CAM;
    const s = FOCAL / Math.max(0.05, zc);
    return { sx: CX + x1 * s * SCALE, sy: CY - y2 * s * SCALE, s, zc };
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // point cloud (additive glow)
    ctx.globalCompositeOperation = 'lighter';
    const count = Math.min(state.count, nPoints);
    for (let i = 0; i < count; i++) {
      const p = project(px[i], py[i], pz[i]);
      if (p.zc <= 0.1) continue;
      const c = turbo(pt[i]);
      const alpha = 0.1 + 0.55 * pt[i];
      const r = Math.max(0.7, 1.7 * p.s);
      ctx.fillStyle = `rgba(${c[0]},${c[1]},${c[2]},${alpha})`;
      ctx.beginPath();
      ctx.arc(p.sx, p.sy, r, 0, 6.2832);
      ctx.fill();
    }
    ctx.globalCompositeOperation = 'source-over';

    // gradient arrows
    if (state.showGrad) {
      ctx.lineWidth = 1.4;
      for (const a of arrows) {
        const b = project(a.bx, a.by, a.bz);
        const t = project(a.tx, a.ty, a.tz);
        if (b.zc <= 0.1 || t.zc <= 0.1) continue;
        const depth = Math.max(0.25, Math.min(1, 1.6 - (b.zc - CAM + 1)));
        ctx.strokeStyle = `rgba(235,238,245,${0.35 + 0.45 * depth})`;
        ctx.beginPath();
        ctx.moveTo(b.sx, b.sy);
        ctx.lineTo(t.sx, t.sy);
        ctx.stroke();
        // arrowhead
        const ang = Math.atan2(t.sy - b.sy, t.sx - b.sx);
        const hs = 5;
        ctx.beginPath();
        ctx.moveTo(t.sx, t.sy);
        ctx.lineTo(t.sx - hs * Math.cos(ang - 0.5), t.sy - hs * Math.sin(ang - 0.5));
        ctx.moveTo(t.sx, t.sy);
        ctx.lineTo(t.sx - hs * Math.cos(ang + 0.5), t.sy - hs * Math.sin(ang + 0.5));
        ctx.stroke();
      }
    }
  }

  // ---- interaction ----
  let dragging = false;
  let lastX = 0, lastY = 0;
  canvas.addEventListener('pointerdown', (e) => {
    dragging = true;
    lastX = e.clientX;
    lastY = e.clientY;
    canvas.setPointerCapture(e.pointerId);
  });
  canvas.addEventListener('pointermove', (e) => {
    if (!dragging) return;
    state.yaw += (e.clientX - lastX) * 0.01;
    state.pitch += (e.clientY - lastY) * 0.01;
    state.pitch = Math.max(-1.45, Math.min(1.45, state.pitch));
    lastX = e.clientX;
    lastY = e.clientY;
  });
  const stop = () => (dragging = false);
  canvas.addEventListener('pointerup', stop);
  canvas.addEventListener('pointercancel', stop);

  // ---- controls ----
  const ptsEl = document.getElementById('pts') as HTMLInputElement;
  ptsEl.addEventListener('input', () => {
    state.count = +ptsEl.value;
    (document.getElementById('ptval') as HTMLElement).textContent = ptsEl.value;
  });

  document.getElementById('grad')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    document.querySelectorAll('#grad button').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
    state.showGrad = btn.dataset.on === '1';
  });

  const spinBtn = document.getElementById('spin') as HTMLButtonElement;
  spinBtn.addEventListener('click', () => {
    state.spin = !state.spin;
    spinBtn.textContent = state.spin ? 'Pause spin' : 'Resume spin';
  });

  document.getElementById('regen')!.addEventListener('click', generate);

  // ---- loop ----
  function loop() {
    if (state.spin && !dragging) state.yaw += 0.0035;
    draw();
    requestAnimationFrame(loop);
  }

  generate();
  loop();
</script>

<style>
  .probe-canvas {
    cursor: grab;
    touch-action: none;
  }
  .probe-canvas:active {
    cursor: grabbing;
  }
</style>

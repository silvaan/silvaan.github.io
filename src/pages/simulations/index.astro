---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AREAS } from '../../data/tools';
---

<BaseLayout
  title="Simulations"
  description="Interactive simulations grouped by area: calculus, linear algebra and deep learning."
  wide
>
  <div class="page-head">
    <span class="eyebrow">Playground</span>
    <h1>Simulations</h1>
    <p class="lead">
      Interactive simulations, grouped by area. Pick a topic to see what's
      inside.
    </p>
  </div>

  <div class="card-grid">
    {
      AREAS.map((area) => (
        <a class="card" href={`/simulations/${area.slug}`}>
          <span class="icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d={area.icon} />
            </svg>
          </span>
          <h3>{area.title}</h3>
          <p>{area.description}</p>
          <div class="card-foot">
            <span>{area.simulators.length} simulator{area.simulators.length === 1 ? '' : 's'}</span>
            <span class="arrow">→</span>
          </div>
        </a>
      ))
    }
  </div>
</BaseLayout>

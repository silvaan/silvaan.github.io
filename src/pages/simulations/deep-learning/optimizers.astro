---
import SimLayout from '../../../layouts/SimLayout.astro';
---

<SimLayout
  areaSlug="deep-learning"
  title="Optimizer Showdown"
  description="Five optimizers descending the same 3D loss surface. Click the surface to set where they start, give each its own learning rate and hyperparameters, show the gradient and momentum arrows, and step frame by frame to compare SGD, Momentum, Nesterov, RMSProp and Adam."
>
  <div class="sim">
    <div class="sim-stage">
      <canvas id="opt" class="probe-canvas" width="660" height="620"></canvas>
    </div>

    <div class="sim-panel">
      <div class="control">
        <label>Surface</label>
        <div class="seg" id="surf">
          <button data-s="saddle" class="active">Saddle</button>
          <button data-s="wells">Two wells</button>
          <button data-s="ripples">Ripples</button>
          <button data-s="ravine">Ravine</button>
          <button data-s="monkey">Monkey</button>
          <button data-s="basin">Basin</button>
          <button data-s="eggcarton">Egg carton</button>
          <button data-s="banana">Banana</button>
        </div>
      </div>

      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn" id="run">Pause</button>
        <button class="btn ghost" id="step">Step</button>
        <button class="btn ghost" id="reset">Reset</button>
        <button class="btn ghost" id="newstart">Random start</button>
      </div>

      <div class="control">
        <label>Speed (steps / sec) <b id="spval">10</b></label>
        <input type="range" id="sp" min="2" max="80" value="10" />
      </div>

      <div class="control">
        <label>Arrows</label>
        <div class="seg" id="arrows">
          <button data-a="grad">Gradient</button>
          <button data-a="mom">Momentum</button>
        </div>
      </div>

      <div class="block-label">Optimizers</div>
      <div id="sections"></div>

      <div class="readout">
        <div class="row"><span>Iteration</span><b id="iter">0</b></div>
      </div>

      <p style="font-size:.82rem;color:var(--text-faint);margin:0;line-height:1.5">
        Drag to orbit, scroll to zoom, click the surface to drop the start point
        there. Click an optimizer's coloured dot to toggle it on or off. The
        dashed white arrow is the downhill gradient; the coloured arrow is its
        momentum.
      </p>
    </div>
  </div>
</SimLayout>

<script>
  const canvas = document.getElementById('opt') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const W = canvas.width;
  const H = canvas.height;
  const CX = W / 2;
  const CY = H / 2;
  const CAM = 3.2;
  const FOCAL = 2.7;
  const SCALE = 250;
  const D = 2;
  const EPS = 1e-7;

  type Surf = {
    f: (x: number, y: number) => number;
    g: (x: number, y: number) => { x: number; y: number };
  };
  const SURFACES: Record<string, Surf> = {
    saddle: { f: (x, y) => 0.5 * (x * x - y * y), g: (x, y) => ({ x, y: -y }) },
    wells: {
      f: (x, y) => 0.6 * (x * x - 1) ** 2 + 0.5 * y * y,
      g: (x, y) => ({ x: 2.4 * x * (x * x - 1), y }),
    },
    ripples: {
      f: (x, y) => 0.18 * (x * x + y * y) - 0.5 * Math.cos(2.2 * x) - 0.5 * Math.cos(2.2 * y),
      g: (x, y) => ({ x: 0.36 * x + 1.1 * Math.sin(2.2 * x), y: 0.36 * y + 1.1 * Math.sin(2.2 * y) }),
    },
    ravine: {
      f: (x, y) => 0.035 * x * x + 1.4 * y * y,
      g: (x, y) => ({ x: 0.07 * x, y: 2.8 * y }),
    },
    monkey: {
      f: (x, y) => 0.4 * (x * x * x - 3 * x * y * y),
      g: (x, y) => ({ x: 1.2 * (x * x - y * y), y: -2.4 * x * y }),
    },
    basin: {
      f: (x, y) => 1 - Math.exp(-(x * x + y * y)),
      g: (x, y) => { const e = Math.exp(-(x * x + y * y)); return { x: 2 * x * e, y: 2 * y * e }; },
    },
    eggcarton: {
      f: (x, y) => 0.2 * (x * x + y * y) + 0.5 * Math.sin(2.5 * x) * Math.sin(2.5 * y),
      g: (x, y) => ({
        x: 0.4 * x + 1.25 * Math.cos(2.5 * x) * Math.sin(2.5 * y),
        y: 0.4 * y + 1.25 * Math.sin(2.5 * x) * Math.cos(2.5 * y),
      }),
    },
    banana: {
      f: (x, y) => 0.02 * (1 - x) ** 2 + 0.2 * (y - x * x) ** 2,
      g: (x, y) => ({
        x: -0.04 * (1 - x) - 0.8 * x * (y - x * x),
        y: 0.4 * (y - x * x),
      }),
    },
  };

  type Cfg = { on: boolean; lr: number; momentum: number; rho: number; beta1: number; beta2: number };
  type RT = { x: number; y: number; mx: number; my: number; vx: number; vy: number; t: number };

  const DEFS: { name: string; color: string; uses: string[]; step: (o: RT, c: Cfg, g: Surf['g']) => void }[] = [
    {
      name: 'SGD', color: '#f87171', uses: ['lr'],
      step: (o, c, g) => { const d = g(o.x, o.y); o.x -= c.lr * d.x; o.y -= c.lr * d.y; },
    },
    {
      name: 'Momentum', color: '#fbbf24', uses: ['lr', 'momentum'],
      step: (o, c, g) => {
        const d = g(o.x, o.y);
        o.vx = c.momentum * o.vx - c.lr * d.x; o.vy = c.momentum * o.vy - c.lr * d.y;
        o.x += o.vx; o.y += o.vy;
      },
    },
    {
      name: 'Nesterov', color: '#34d399', uses: ['lr', 'momentum'],
      step: (o, c, g) => {
        const d = g(o.x + c.momentum * o.vx, o.y + c.momentum * o.vy);
        o.vx = c.momentum * o.vx - c.lr * d.x; o.vy = c.momentum * o.vy - c.lr * d.y;
        o.x += o.vx; o.y += o.vy;
      },
    },
    {
      name: 'RMSProp', color: '#60a5fa', uses: ['lr', 'rho'],
      step: (o, c, g) => {
        const d = g(o.x, o.y);
        o.vx = c.rho * o.vx + (1 - c.rho) * d.x * d.x;
        o.vy = c.rho * o.vy + (1 - c.rho) * d.y * d.y;
        o.x -= (c.lr * d.x) / (Math.sqrt(o.vx) + EPS);
        o.y -= (c.lr * d.y) / (Math.sqrt(o.vy) + EPS);
      },
    },
    {
      name: 'Adam', color: '#c084fc', uses: ['lr', 'beta1', 'beta2'],
      step: (o, c, g) => {
        const d = g(o.x, o.y); o.t++;
        o.mx = c.beta1 * o.mx + (1 - c.beta1) * d.x; o.my = c.beta1 * o.my + (1 - c.beta1) * d.y;
        o.vx = c.beta2 * o.vx + (1 - c.beta2) * d.x * d.x; o.vy = c.beta2 * o.vy + (1 - c.beta2) * d.y * d.y;
        const mhx = o.mx / (1 - c.beta1 ** o.t), mhy = o.my / (1 - c.beta1 ** o.t);
        const vhx = o.vx / (1 - c.beta2 ** o.t), vhy = o.vy / (1 - c.beta2 ** o.t);
        o.x -= (c.lr * mhx) / (Math.sqrt(vhx) + EPS);
        o.y -= (c.lr * mhy) / (Math.sqrt(vhy) + EPS);
      },
    },
  ];

  // velocity vector to show as the "momentum" arrow (null where not meaningful)
  function momentumOf(i: number): { x: number; y: number } | null {
    const o = rt[i];
    const n = DEFS[i].name;
    if (n === 'Momentum' || n === 'Nesterov') return { x: o.vx, y: o.vy };
    if (n === 'Adam') return { x: o.mx, y: o.my };
    return null;
  }

  const PMETA: Record<string, { label: string; min: number; max: number; scale: number; fmt: number }> = {
    lr: { label: 'Learning rate', min: 2, max: 200, scale: 1000, fmt: 3 },
    momentum: { label: 'Momentum β', min: 0, max: 99, scale: 100, fmt: 2 },
    rho: { label: 'Decay ρ', min: 500, max: 999, scale: 1000, fmt: 3 },
    beta1: { label: 'β₁', min: 0, max: 99, scale: 100, fmt: 2 },
    beta2: { label: 'β₂', min: 9000, max: 9999, scale: 10000, fmt: 4 },
  };

  const cfg: Cfg[] = DEFS.map(() => ({ on: true, lr: 0.03, momentum: 0.9, rho: 0.9, beta1: 0.9, beta2: 0.999 }));
  let rt: RT[] = [];
  const trails: { x: number; y: number }[][] = [];

  const state = {
    yaw: 0.7, pitch: -0.62, surf: 'saddle', speed: 10, running: true,
    iter: 0, start: { x: 1.0, y: 0.7 }, showGrad: false, showMom: false, zoom: 1,
  };
  let fmin = 0, fspan = 1;

  const curF = (x: number, y: number) => SURFACES[state.surf].f(x, y);

  function computeRange() {
    fmin = Infinity; let fmax = -Infinity;
    for (let i = 0; i <= 40; i++)
      for (let j = 0; j <= 40; j++) {
        const f = curF(-D + (2 * D * i) / 40, -D + (2 * D * j) / 40);
        if (f < fmin) fmin = f;
        if (f > fmax) fmax = f;
      }
    fspan = fmax - fmin || 1;
  }

  function worldOf(x: number, y: number) {
    const wy = ((curF(x, y) - fmin) / fspan) * 1.3 - 0.65;
    return project(x / D, wy, y / D);
  }

  function project(x: number, y: number, z: number) {
    const cy = Math.cos(state.yaw), sy = Math.sin(state.yaw);
    const cp = Math.cos(state.pitch), sp = Math.sin(state.pitch);
    const x1 = x * cy + z * sy;
    const z1 = -x * sy + z * cy;
    const y2 = y * cp - z1 * sp;
    const z2 = y * sp + z1 * cp;
    const zc = z2 + CAM;
    const s = FOCAL / Math.max(0.05, zc);
    const k = s * SCALE * state.zoom;
    return { sx: CX + x1 * k, sy: CY - y2 * k, s: s * state.zoom, zc };
  }

  function turbo(t: number) {
    t = Math.max(0, Math.min(1, t));
    const stops = [[40, 60, 150], [30, 150, 200], [50, 200, 120], [240, 200, 70], [235, 80, 70]];
    const seg = t * (stops.length - 1);
    const i = Math.min(stops.length - 2, Math.floor(seg));
    const f = seg - i;
    const a = stops[i], b = stops[i + 1];
    return `rgb(${(a[0] + (b[0] - a[0]) * f) | 0},${(a[1] + (b[1] - a[1]) * f) | 0},${(a[2] + (b[2] - a[2]) * f) | 0})`;
  }

  function resetOpts() {
    rt = DEFS.map(() => ({ x: state.start.x, y: state.start.y, mx: 0, my: 0, vx: 0, vy: 0, t: 0 }));
    state.iter = 0;
    trails.length = 0;
    for (let i = 0; i < DEFS.length; i++) trails.push([{ ...state.start }]);
  }

  function stepAll() {
    const g = SURFACES[state.surf].g;
    DEFS.forEach((def, i) => {
      if (!cfg[i].on) return;
      const o = rt[i];
      if (!isFinite(o.x) || !isFinite(o.y)) return;
      def.step(o, cfg[i], g);
      o.x = Math.max(-D, Math.min(D, o.x));
      o.y = Math.max(-D, Math.min(D, o.y));
      const tr = trails[i];
      tr.push({ x: o.x, y: o.y });
      if (tr.length > 600) tr.shift();
    });
    state.iter++;
  }

  function arrow(x: number, y: number, dx: number, dy: number, L: number, color: string, dashed: boolean) {
    const a = worldOf(x, y);
    const b = worldOf(x + dx * L, y + dy * L);
    if (a.zc <= 0.1 || b.zc <= 0.1) return;
    ctx.strokeStyle = color; ctx.fillStyle = color; ctx.lineWidth = 2;
    if (dashed) ctx.setLineDash([4, 3]);
    ctx.beginPath(); ctx.moveTo(a.sx, a.sy); ctx.lineTo(b.sx, b.sy); ctx.stroke();
    ctx.setLineDash([]);
    const ang = Math.atan2(b.sy - a.sy, b.sx - a.sx);
    const hs = 7;
    ctx.beginPath();
    ctx.moveTo(b.sx, b.sy);
    ctx.lineTo(b.sx - hs * Math.cos(ang - 0.45), b.sy - hs * Math.sin(ang - 0.45));
    ctx.lineTo(b.sx - hs * Math.cos(ang + 0.45), b.sy - hs * Math.sin(ang + 0.45));
    ctx.closePath(); ctx.fill();
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    const M = 30;
    for (let i = 0; i <= M; i++) {
      for (const axis of [0, 1]) {
        ctx.beginPath();
        let started = false;
        for (let j = 0; j <= M; j++) {
          const a = -D + (2 * D * i) / M;
          const b = -D + (2 * D * j) / M;
          const x = axis === 0 ? b : a;
          const y = axis === 0 ? a : b;
          const p = worldOf(x, y);
          if (p.zc <= 0.1) { started = false; continue; }
          if (!started) { ctx.moveTo(p.sx, p.sy); started = true; } else ctx.lineTo(p.sx, p.sy);
        }
        const a = -D + (2 * D * i) / M;
        const tH = (curF(axis === 0 ? 0 : a, axis === 0 ? a : 0) - fmin) / fspan;
        ctx.strokeStyle = turbo(tH);
        ctx.globalAlpha = 0.38;
        ctx.lineWidth = 1;
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
    }

    const sm = worldOf(state.start.x, state.start.y);
    if (sm.zc > 0.1) {
      ctx.strokeStyle = 'rgba(255,255,255,0.55)';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.arc(sm.sx, sm.sy, 4, 0, 6.2832);
      ctx.stroke();
    }

    DEFS.forEach((def, i) => {
      if (!cfg[i].on) return;
      const tr = trails[i];
      ctx.strokeStyle = def.color;
      ctx.lineWidth = 2;
      ctx.globalAlpha = 0.85;
      ctx.beginPath();
      let started = false;
      for (const pt of tr) {
        const p = worldOf(pt.x, pt.y);
        if (p.zc <= 0.1) { started = false; continue; }
        if (!started) { ctx.moveTo(p.sx, p.sy); started = true; } else ctx.lineTo(p.sx, p.sy);
      }
      ctx.stroke();
      ctx.globalAlpha = 1;

      const o = rt[i];
      // arrows
      if (state.showGrad) {
        const g = SURFACES[state.surf].g(o.x, o.y);
        const m = Math.hypot(g.x, g.y);
        if (m > 1e-5) arrow(o.x, o.y, -g.x / m, -g.y / m, 0.34, 'rgba(255,255,255,0.92)', true);
      }
      if (state.showMom) {
        const v = momentumOf(i);
        if (v) {
          const m = Math.hypot(v.x, v.y);
          if (m > 1e-5) arrow(o.x, o.y, v.x / m, v.y / m, Math.min(0.55, m * 5) + 0.05, def.color, false);
        }
      }

      const p = worldOf(o.x, o.y);
      if (p.zc > 0.1) {
        ctx.fillStyle = def.color;
        ctx.beginPath();
        ctx.arc(p.sx, p.sy, Math.max(3.5, 4.5 * p.s), 0, 6.2832);
        ctx.fill();
        ctx.strokeStyle = 'rgba(0,0,0,0.5)';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    });

    (document.getElementById('iter') as HTMLElement).textContent = String(state.iter);
    drawGizmo();
  }

  function drawGizmo() {
    const ox = 50, oy = H - 50, len = 28;
    const cy = Math.cos(state.yaw), sy = Math.sin(state.yaw);
    const cp = Math.cos(state.pitch), sp = Math.sin(state.pitch);
    const axes = [
      { v: [1, 0, 0], c: '#f87171', l: 'x' },
      { v: [0, 1, 0], c: '#4ade80', l: 'f' },
      { v: [0, 0, 1], c: '#60a5fa', l: 'y' },
    ];
    const proj = axes.map((a) => {
      const [x, y, z] = a.v;
      const x1 = x * cy + z * sy;
      const z1 = -x * sy + z * cy;
      const y2 = y * cp - z1 * sp;
      const z2 = y * sp + z1 * cp;
      return { ex: ox + x1 * len, ey: oy - y2 * len, depth: z2, c: a.c, l: a.l };
    });
    proj.sort((a, b) => a.depth - b.depth);
    ctx.lineWidth = 2;
    ctx.font = "600 11px 'JetBrains Mono', monospace";
    for (const a of proj) {
      ctx.strokeStyle = a.c; ctx.fillStyle = a.c;
      ctx.beginPath(); ctx.moveTo(ox, oy); ctx.lineTo(a.ex, a.ey); ctx.stroke();
      ctx.beginPath(); ctx.arc(a.ex, a.ey, 2.3, 0, 6.2832); ctx.fill();
      ctx.fillText(a.l, a.ex + 3, a.ey - 3);
    }
  }

  // per-optimizer sections: coloured dot (toggle on/off) + collapsible params
  const sections = document.getElementById('sections')!;
  sections.innerHTML = DEFS
    .map((d, i) => {
      const rows = d.uses
        .map((p) => {
          const m = PMETA[p];
          const val = (cfg[i] as any)[p] as number;
          return `<div class="control"><label>${m.label} <b id="v-${i}-${p}">${val.toFixed(m.fmt)}</b></label><input type="range" id="s-${i}-${p}" min="${m.min}" max="${m.max}" value="${Math.round(val * m.scale)}"></div>`;
        })
        .join('');
      return `<details class="opt-params"><summary><button class="dot" data-i="${i}" title="toggle" style="background:${d.color}"></button><span class="onm">${d.name}</span></summary><div class="opt-params-body">${rows}</div></details>`;
    })
    .join('');

  // dot click toggles the optimizer (without opening/closing the section)
  sections.addEventListener('click', (e) => {
    const dot = (e.target as HTMLElement).closest('.dot') as HTMLElement | null;
    if (!dot) return;
    e.preventDefault();
    const i = +dot.dataset.i!;
    cfg[i].on = !cfg[i].on;
    (dot.closest('.opt-params') as HTMLElement).classList.toggle('off', !cfg[i].on);
  });

  sections.querySelectorAll('input').forEach((el) => {
    el.addEventListener('input', () => {
      const [, iStr, p] = el.id.split('-');
      const i = +iStr;
      const m = PMETA[p];
      const v = +(el as HTMLInputElement).value / m.scale;
      (cfg[i] as any)[p] = v;
      (document.getElementById(`v-${i}-${p}`) as HTMLElement).textContent = v.toFixed(m.fmt);
    });
  });

  // ---- click on surface to set start ----
  function pickStart(clientX: number, clientY: number) {
    const rect = canvas.getBoundingClientRect();
    const mx = ((clientX - rect.left) / rect.width) * W;
    const my = ((clientY - rect.top) / rect.height) * H;
    let bestD = Infinity, bx = 0, by = 0, found = false;
    const G = 80;
    for (let i = 0; i <= G; i++)
      for (let j = 0; j <= G; j++) {
        const x = -D + (2 * D * i) / G;
        const y = -D + (2 * D * j) / G;
        const p = worldOf(x, y);
        if (p.zc <= 0.1) continue;
        const d = (p.sx - mx) ** 2 + (p.sy - my) ** 2;
        if (d < bestD) { bestD = d; bx = x; by = y; found = true; }
      }
    if (found && bestD < 44 * 44) {
      state.start = { x: bx, y: by };
      resetOpts();
    }
  }

  // ---- interaction (orbit vs click) ----
  let dragging = false, moved = false, lastX = 0, lastY = 0, downX = 0, downY = 0;
  canvas.addEventListener('pointerdown', (e) => {
    dragging = true; moved = false;
    lastX = e.clientX; lastY = e.clientY; downX = e.clientX; downY = e.clientY;
    canvas.setPointerCapture(e.pointerId);
  });
  canvas.addEventListener('pointermove', (e) => {
    if (!dragging) return;
    if (Math.hypot(e.clientX - downX, e.clientY - downY) > 4) moved = true;
    state.yaw += (e.clientX - lastX) * 0.01;
    state.pitch = Math.max(-1.45, Math.min(-0.05, state.pitch + (e.clientY - lastY) * 0.01));
    lastX = e.clientX; lastY = e.clientY;
    if (!state.running) draw();
  });
  canvas.addEventListener('pointerup', (e) => {
    dragging = false;
    if (!moved) pickStart(e.clientX, e.clientY);
  });
  canvas.addEventListener('pointercancel', () => (dragging = false));

  canvas.addEventListener(
    'wheel',
    (e) => {
      e.preventDefault();
      state.zoom *= e.deltaY < 0 ? 1.1 : 1 / 1.1;
      state.zoom = Math.max(0.5, Math.min(4, state.zoom));
      if (!state.running) draw();
    },
    { passive: false }
  );

  // ---- controls ----
  document.getElementById('surf')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    document.querySelectorAll('#surf button').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
    state.surf = btn.dataset.s!;
    computeRange();
    resetOpts();
  });

  document.getElementById('arrows')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    btn.classList.toggle('active');
    const on = btn.classList.contains('active');
    if (btn.dataset.a === 'grad') state.showGrad = on; else state.showMom = on;
    if (!state.running) draw();
  });

  const spEl = document.getElementById('sp') as HTMLInputElement;
  spEl.addEventListener('input', () => {
    state.speed = +spEl.value;
    (document.getElementById('spval') as HTMLElement).textContent = spEl.value;
  });

  const runBtn = document.getElementById('run') as HTMLButtonElement;
  runBtn.addEventListener('click', () => {
    state.running = !state.running;
    runBtn.textContent = state.running ? 'Pause' : 'Run';
  });
  document.getElementById('step')!.addEventListener('click', () => { stepAll(); draw(); });
  document.getElementById('reset')!.addEventListener('click', resetOpts);
  document.getElementById('newstart')!.addEventListener('click', () => {
    state.start = { x: +(Math.random() * 3 - 1.5).toFixed(2), y: +(Math.random() * 3 - 1.5).toFixed(2) };
    resetOpts();
  });

  // ---- loop with time-based stepping ----
  let last = 0, acc = 0;
  function loop(ts: number) {
    if (!last) last = ts;
    const dt = Math.min(0.1, (ts - last) / 1000);
    last = ts;
    if (state.running) {
      acc += dt * state.speed;
      let n = 0;
      while (acc >= 1 && n < 300) { stepAll(); acc -= 1; n++; }
    }
    draw();
    requestAnimationFrame(loop);
  }

  computeRange();
  resetOpts();
  requestAnimationFrame(loop);
</script>

